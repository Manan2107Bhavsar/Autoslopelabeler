<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0-windows</TargetFramework>
		<Platforms>x64</Platforms>
		<Nullable>enable</Nullable>
		<ImplicitUsings>disable</ImplicitUsings>
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<OutputType>Library</OutputType>
		<AssemblyName>AutoSlopeLabeler</AssemblyName>
		<RootNamespace>AutoSlopeLabeler</RootNamespace>

		<!-- Required for WPF Window, Button, ListBox etc. -->
		<UseWPF>true</UseWPF>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="AutoCAD.NET" Version="25.1.0" />
		<PackageReference Include="Civil3D.NET" Version="13.8.946" />
	</ItemGroup>

</Project>